# Jira credentials
JIRA_BASE_URL=https://ninjio.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your_api_token

# Jira project keys
JIRA_EM_PROJECT=EM-TASKS
JIRA_TEAM_PROJECTS=SAOP,SAOP2

# Scheduler cron settings
POLL_INTERVAL_MINUTES=15
GAP_DETECTION_CRON=0 6 * * 1
STACK_RANK_CRON=30 7 * * 5
REPORT_CRON=0 17 * * 4

# Optional: stack rank script path
STACK_RANK_SCRIPT=

# Optional: cloud provider for infra cost tracking
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# CLOUD_PROVIDER=aws

# App settings
APP_PORT=8765
AUTO_OPEN_BROWSER=true
